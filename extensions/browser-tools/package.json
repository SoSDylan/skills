{
  "name": "pi-browser-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A Pi extension for driving visible Google Chrome with Playwright",
  "scripts": {
    "check": "tsc --noEmit",
    "test": "npm run test:commands && npm run test:concurrency",
    "test:commands": "node --experimental-strip-types test/browser-command.mjs",
    "test:concurrency": "node --experimental-strip-types test/concurrent-agents.mjs"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "playwright-core": "1.61.1",
    "typebox": "1.1.38"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.80.7",
    "@types/node": "24.10.1",
    "typescript": "5.9.3"
  }
}
